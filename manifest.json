{
  "manifest_version": 3,
  "name": "Shorts Blocker",
  "version": "1.0.0",
  "description": "Blocks YouTube Shorts and removes recommended videos to help you stay focused.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shorts Blocker"
  }
}
